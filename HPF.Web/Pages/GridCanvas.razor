@using HPF.model
@using HPF.Web.Models
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS

<div class="canvas-wrapper"
     @onmousedown="StartPan"
     @onmousemove="Pan"
     @onmouseup="EndPan"
     @onmouseleave="EndPan"
     @onwheel="Zoom"
     @onwheel:preventDefault="true">

    <canvas class="grid-canvas" @ref="canvas"></canvas>

</div>

<div class="timeline-panel">

    <button @onclick="TogglePlayback">
        @(isPlaying ? "Pause" : "Play")
    </button>

    <input type="range"
           min="0"
           max="@MaxFrame"
           value="@currentFrame"
           @oninput="OnSliderChanged" />

    <span>
        @currentFrame / @MaxFrame
    </span>

</div>

@code {

    [Parameter] public GeneratedMap? Map { get; set; }
    [Parameter] public GridMap? GridMap { get; set; }
    [Parameter] public FinalPathDto? Path { get; set; }
    [Parameter] public AppConfig? Config { get; set; }

    private ElementReference canvas;

    private double offsetX = 20;
    private double offsetY = 20;
    private double scale = 1;

    private bool dragging;
    private double lastX;
    private double lastY;

    private bool _initialized;
    private bool _dataCached;

    private int currentFrame = 0;
    private bool isPlaying = false;

    // Unique ID for this component instance so the JS cache key is stable
    private readonly string _cacheId = Guid.NewGuid().ToString("N");

    // ---------------------------------------------------------------
    // Lifecycle
    // ---------------------------------------------------------------

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _initialized = true;
            await PushStaticData();
            await DrawView();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        currentFrame = 0;
        isPlaying = false;
        playCts?.Cancel();
        _dataCached = false;

        if (_initialized)
        {
            await PushStaticData();
            await DrawView();
        }
    }

    // ---------------------------------------------------------------
    // JS interop helpers
    // ---------------------------------------------------------------

    /// <summary>
    /// Sends heavy, rarely-changing data to the JS cache once.
    /// After this call, Draw() only needs to pass view-state scalars.
    /// </summary>
    private async Task PushStaticData()
    {
        if (Map is null || _dataCached)
            return;

        await JS.InvokeVoidAsync(
            "gridRenderer.setData",
            _cacheId,
            Map,
            GridMap is null ? null : ToDto(GridMap),
            Path,
            Config
        );

        _dataCached = true;
    }

    /// <summary>
    /// Hot draw call — tiny payload, no heavy objects.
    /// </summary>
    private async Task DrawView()
    {
        if (!_dataCached)
            return;

        await JS.InvokeVoidAsync(
            "gridRenderer.draw",
            canvas,
            _cacheId,
            scale,
            offsetX,
            offsetY,
            currentFrame
        );
    }

    // ---------------------------------------------------------------
    // Pan / Zoom
    // ---------------------------------------------------------------

    private void StartPan(MouseEventArgs e)
    {
        dragging = true;
        lastX = e.ClientX;
        lastY = e.ClientY;
    }

    private async Task Pan(MouseEventArgs e)
    {
        if (!dragging)
            return;

        offsetX += e.ClientX - lastX;
        offsetY += e.ClientY - lastY;

        lastX = e.ClientX;
        lastY = e.ClientY;

        await DrawView();
    }

    private void EndPan(MouseEventArgs e) => dragging = false;

    private async Task Zoom(WheelEventArgs e)
    {
        double zoomSpeed = 0.001;
        double newScale = Math.Clamp(scale - e.DeltaY * zoomSpeed, 0.1, 8);

        double ratio = newScale / scale;
        offsetX = e.OffsetX - (e.OffsetX - offsetX) * ratio;
        offsetY = e.OffsetY - (e.OffsetY - offsetY) * ratio;

        scale = newScale;
        await DrawView();
    }

    // ---------------------------------------------------------------
    // Playback
    // ---------------------------------------------------------------

    private CancellationTokenSource? playCts;

    private int MaxFrame =>
        Path?.AnimationSteps?.Count > 0
            ? Path.AnimationSteps.Count - 1
            : 0;

    private async Task TogglePlayback()
    {
        if (isPlaying) { Pause(); return; }
        await Play();
    }

    private async Task Play()
    {
        if (Path is null || isPlaying)
            return;

        isPlaying = true;
        playCts?.Cancel();
        playCts = new CancellationTokenSource();
        var token = playCts.Token;

        try
        {
            while (currentFrame < MaxFrame)
            {
                if (token.IsCancellationRequested)
                    break;

                currentFrame++;
                await DrawView();
                StateHasChanged();
                await Task.Delay(25, token);
            }
        }
        catch (TaskCanceledException) { /* expected on Pause */ }
        finally
        {
            isPlaying = false;
        }
    }

    private void Pause()
    {
        playCts?.Cancel();
        isPlaying = false;
    }

    /// <summary>
    /// Called by JS when the animation reaches the last frame.
    /// </summary>
    [JSInvokable]
    public void OnPlaybackEnded(int finalFrame)
    {
        currentFrame = finalFrame;
        isPlaying = false;
        playCts?.Cancel();
        StateHasChanged();
    }

    /// <summary>
    /// Called by JS on each frame tick so the slider stays in sync
    /// without Blazor needing to drive the loop.
    /// </summary>
    [JSInvokable]
    public void OnFrameTick(int frame)
    {
        currentFrame = frame;
        StateHasChanged();
    }

    private async Task OnSliderChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out int value))
            return;

        currentFrame = value;
        await DrawView();
    }

    // ---------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------

    private static GridMapDto ToDto(GridMap grid) => new()
    {
        GridSize = grid.GridSize,
        AllGates = grid.GetAllGates()
            .Select(g => new GateDto
            {
                Pos = g.Pos,
                Connections = g.Connections.Select(c => c.Pos).ToList()
            })
            .ToList()
    };
}
