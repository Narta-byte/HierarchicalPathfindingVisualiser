@using HPF.model
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS

<div class="canvas-wrapper"
     @onmousedown="StartPan"
     @onmousemove="Pan"
     @onmouseup="EndPan"
     @onmouseleave="EndPan"
     @onwheel="Zoom">

    <canvas class="grid-canvas"
            @ref="canvas">
    </canvas>

</div>

@code {

    [Parameter]
    public GeneratedMap? Map { get; set; }

    private ElementReference canvas;

    private double offsetX = 20;
    private double offsetY = 20;

    private double scale = 1;

    private bool dragging;

    private double lastX;
    private double lastY;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await Draw();
    }

    protected override async Task OnParametersSetAsync()
    {
        await Draw();
    }

    private async Task Draw()
    {
        if (Map == null)
            return;

        await JS.InvokeVoidAsync(
            "gridRenderer.draw",
            canvas,
            Map.Rows,
            Map.Cols,
            Map.MapString,
            scale,
            offsetX,
            offsetY
        );
    }

    private void StartPan(MouseEventArgs e)
    {
        dragging = true;

        lastX = e.ClientX;
        lastY = e.ClientY;
    }

    private async Task Pan(MouseEventArgs e)
    {
        if (!dragging)
            return;

        offsetX += e.ClientX - lastX;
        offsetY += e.ClientY - lastY;

        lastX = e.ClientX;
        lastY = e.ClientY;

        await Draw();
    }

    private void EndPan(MouseEventArgs e)
    {
        dragging = false;
    }

    private async Task Zoom(WheelEventArgs e)
    {
        double zoomSpeed = 0.001;

        double newScale = scale - e.DeltaY * zoomSpeed;

        scale = Math.Clamp(newScale, 0.1, 8);

        await Draw();
    }
}