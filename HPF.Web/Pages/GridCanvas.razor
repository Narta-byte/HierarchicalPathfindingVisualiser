@using HPF.model
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS

<div class="canvas-wrapper"
     @onmousedown="StartPan"
     @onmousemove="Pan"
     @onmouseup="EndPan"
     @onmouseleave="EndPan"
     @onwheel="Zoom">

    <canvas class="grid-canvas" @ref="canvas"></canvas>

</div>

@code {
    public class GridMapDto {
        public int GridSize { get; set; }
        public List<GateDto> AllGates { get; set; } = new();
    }

    public class GateDto {
        public Vector2 Pos { get; set; }
        public List<Vector2> Connections { get; set; } = new();
    }
    [Parameter] public GeneratedMap? Map { get; set; }
    [Parameter] public GridMap? GridMap { get; set; }
    [Parameter] public FinalPath? Path { get; set; }
    [Parameter] public AppConfig? Config { get; set; }

    private ElementReference canvas;

    private double offsetX = 20;
    private double offsetY = 20;
    private double scale = 1;

    private bool dragging;
    private double lastX;
    private double lastY;

    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _initialized = true;
            await Draw();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized)
            return;

        await Draw();
    }

    private async Task Draw()
    {
        if (Map is null)
            return;

        await JS.InvokeVoidAsync(
            "gridRenderer.draw",
            canvas,
            Map,
            GridMap is null ? null : ToDto(GridMap),
            Path,
            Config,
            scale,
            offsetX,
            offsetY
        );
    }

    private void StartPan(MouseEventArgs e)
    {
        dragging = true;
        lastX = e.ClientX;
        lastY = e.ClientY;
    }

    private async Task Pan(MouseEventArgs e)
    {
        if (!dragging)
            return;

        offsetX += e.ClientX - lastX;
        offsetY += e.ClientY - lastY;

        lastX = e.ClientX;
        lastY = e.ClientY;

        await Draw();
    }

    private void EndPan(MouseEventArgs e)
    {
        dragging = false;
    }

    private async Task Zoom(WheelEventArgs e)
    {
        double zoomSpeed = 0.001;

        scale = Math.Clamp(scale - e.DeltaY * zoomSpeed, 0.1, 8);

        await Draw();
    }
    private GridMapDto ToDto(GridMap grid)
{
    return new GridMapDto
    {
        GridSize = grid.GridSize,
        AllGates = grid.GetAllGates()
            .Select(g => new GateDto
            {
                Pos = g.Pos,
                Connections = g.Connections.Select(c => c.Pos).ToList()
            })
            .ToList()
    };
}
}